<!--<persistence version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence           http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">-->
<persistence version="2.1" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_1.xsd">
  <persistence-unit name="procesosPU" transaction-type="JTA">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <jta-data-source>java:/jboss/datasources/iepi3</jta-data-source>
    <class>senadi.com.ditramites.model.postgres.PpdiPersona</class>
    <class>senadi.com.ditramites.model.postgres.PpdiPersonaSolicitudSignoDistintivo</class>
    <class>senadi.com.ditramites.model.postgres.PpdiSolicitudPatente</class>
    <class>senadi.com.ditramites.model.postgres.PpdiSolicitudSignoDistintivo</class>
    <class>senadi.com.ditramites.model.postgres.PpdiTituloSignoDistintivo</class>
    <class>senadi.com.ditramites.model.postgres.PpdiOrdenNiza</class>
    <class>senadi.com.ditramites.model.postgres.PpdiSolicitudOrdenNiza</class>
    <class>senadi.com.ditramites.model.postgres.polaris.HistorialDocUser</class>
    <class>senadi.com.ditramites.model.postgres.polaris.HistorialPatente</class>
    <class>senadi.com.ditramites.model.postgres.polaris.IpasApi</class>
    <class>senadi.com.ditramites.model.postgres.polaris.IpasEnvironment</class>
    <exclude-unlisted-classes>true</exclude-unlisted-classes>
    <properties>
      <property name="wildfly.jpa.default-unit" value="true"/>
