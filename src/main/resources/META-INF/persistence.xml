    <jta-data-source>java:/jboss/datasources/transferencia_prod</jta-data-source>
    <class>senadi.com.ditramites.model.mod.Transferencia</class>
    <class>senadi.com.ditramites.model.mod.CambioNombre</class>
    <class>senadi.com.ditramites.model.mod.CambioDomicilio</class>
    <class>senadi.com.ditramites.model.mod.LicenciaUso</class>
    <class>senadi.com.ditramites.model.mod.PrendaComercial</class>
    <class>senadi.com.ditramites.model.mod.SubLicenciaUso</class>
    <class>senadi.com.ditramites.model.mod.CambioCasillero</class>
    <class>senadi.com.ditramites.model.mod.ConfiguracionCC</class>
    <class>senadi.com.ditramites.model.mod.Usuario</class>
    <exclude-unlisted-classes>true</exclude-unlisted-classes>
    <properties>
        </properties>
  </persistence-unit>
  <persistence-unit name="renovacionPU" transaction-type="JTA">
    <jta-data-source>java:/jboss/datasources/modificacion_prod</jta-data-source>
    <class>senadi.com.ditramites.model.modren.Renovacion</class>
    <exclude-unlisted-classes>true</exclude-unlisted-classes>
    <properties>
    </properties>
  </persistence-unit>
